{
  "name": "@workspace/extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build:popup": "vite build",
    "build:scripts": "npx esbuild src/content/index.ts --bundle --outfile=dist/content.js --platform=browser --minify && npx esbuild src/background/index.ts --bundle --outfile=dist/background.js --platform=browser --minify",
    "build": "pnpm run build:popup && pnpm run build:scripts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/chrome": "^0.0.320",
    "@types/jspdf": "^2.0.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "^0.27.3",
    "tailwindcss": "catalog:",
    "typescript": "~5.9.2",
    "vite": "catalog:"
  }
}
