# WebtoonTranslate API Server
# Copy this to .env and fill in real values

# Server
PORT=5000
NODE_ENV=development

# ── Cloudinary (for image storage) ──────────────────────────────────────────
# Sign up at https://cloudinary.com → Dashboard → API Keys
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ── Google Vision OCR ────────────────────────────────────────────────────────
# Create a service account at https://console.cloud.google.com
# Download the JSON key and set the path here
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Google Cloud Translation ─────────────────────────────────────────────────
# Enable Cloud Translation API in Google Cloud Console
# Either use the service account above, or set a separate API key:
# GOOGLE_CLOUD_API_KEY=your-translation-api-key

# ── Session settings ─────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret-string
